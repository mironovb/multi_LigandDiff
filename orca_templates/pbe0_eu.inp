# PBE0-D4/def2-TZVP; Eu: SARC-DKH-TZVP basis + SK-MCDHF-RSC small-core ECP; gas phase (no implicit solvent)
# Neutral Eu(III) complex: charge=0, mult=7 (4f^6, S=3)
#
# Substitution tokens (replaced by dft_pipeline.py):
#   {xyzfile}  -> path to input xyz
#   {charge}   -> net charge (0 for neutral complex)
#   {mult}     -> spin multiplicity (7 for Eu3+ ground state)
#   {nprocs}   -> PAL parallelism
#   {maxcore}  -> memory per core in MB

! PBE0 def2-TZVP D4 TightSCF SlowConv
! opt

%pal
    nprocs {nprocs}
end

%maxcore {maxcore}

%scf
    MaxIter 300
    DIISMaxEq 15
end

%basis
    NewGTO  Eu "SARC-DKH-TZVP" end
    NewECP  Eu "SK-MCDHF-RSC"  end
end

%geom
    MaxIter 200
end

* xyzfile {charge} {mult} {xyzfile}
